# Use when: The output of actionbar and chatbar is different and with one arg inside and with a button commanded "/trigger tpa.cancel_req"
# Input: List[2] temp.output.chatbar.langs, List[2] temp.output.actionbar.langs, str temp.output.arg, str, str temp.output.arg_hover, str temp.output.button, str temp.output.button_hover
tellraw @s[predicate=tpa:output/show_chatbar] [{interpret: true, storage:"tpa:tpa", nbt:"loaded_lang.header"}, {interpret: true, storage:"tpa:tpa", nbt:"temp.output.chatbar.langs[0]"}, {interpret: true, storage:"tpa:tpa", nbt:"temp.output.arg", hover_event: {action: "show_text", value: {interpret: true, storage: "tpa:tpa", nbt: "temp.output.arg_hover"}}}, {interpret: true, storage:"tpa:tpa", nbt:"temp.chatbar.output.langs[1]"}, " ", {text: "[", extra: [{storage: "tpa:tpa", nbt: "temp.output.button"}, "]"], click_event: {action: "run_command", command: "/trigger tpa.cancel_req"}, hover_event: {action: "show_text", value: {storage: "tpa:tpa", nbt: "temp.output.button_hover"}}}]
title @s[predicate=tpa:output/show_actionbar] actionbar [{interpret: true, storage:"tpa:tpa", nbt:"temp.output.actionbar.langs[0]"}, {interpret: true, storage:"tpa:tpa", nbt:"temp.output.arg"}, {interpret: true, storage:"tpa:tpa", nbt:"temp.output.actionbar.langs[1]"}]

